# ANSIBLE MANAGED — scanner role
# systemd drop-in: harden scanbd and keep USB access available.
[Service]
User={{ scanner_systemd_user }}
Group={{ scanner_systemd_group }}
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
PrivateDevices=false
DeviceAllow=/dev/bus/usb rw
ReadWritePaths={{ scanner_consume_mountpoint }} {{ scanner_tmp_dir }} {{ scanner_log_dir }} /run
CapabilityBoundingSet=
RestrictAddressFamilies=AF_UNIX AF_NETLINK
RestrictNamespaces=true
LockPersonality=true
MemoryDenyWriteExecute=true
SystemCallArchitectures=native
